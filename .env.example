# JanaShakti environment variables — copy to .env and fill in. NEVER commit .env.

# ── Firebase (Project Settings → General → Your apps → SDK config) ──
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=

# ── AI provider ──
# "gemini" (default) uses the Gemini 2.5 Flash chain; "gpt" uses OpenAI gpt-4o-mini.
VITE_AI_PROVIDER=gemini
VITE_GEMINI_API_KEY=your_google_ai_studio_key
VITE_OPENAI_API_KEY=                # only needed when VITE_AI_PROVIDER=gpt

# ── Google Maps JS API ──
VITE_GOOGLE_MAPS_KEY=your_maps_api_key

# ── Cloudinary (short report videos; UNSIGNED upload — no secret key) ──
# Free account → Settings → Upload → add an UNSIGNED upload preset.
# Videos are hosted here (not inline base64 / not Firebase Storage); only the URL
# is saved on the issue doc. Leave blank to disable video uploads.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ── AI proxy (optional) ──
# When set, model calls route through this n8n webhook so the API key stays
# server-side. It must return { "text": "..." }. Leave blank to call AI directly.
VITE_N8N_AI_WEBHOOK=

# ── n8n automation webhooks (optional; app degrades gracefully if blank) ──
VITE_N8N_ISSUE_WEBHOOK=https://your-n8n.cloud/webhook/janashakti-issue
VITE_N8N_SOCIAL_WEBHOOK=https://your-n8n.cloud/webhook/janashakti-social
VITE_N8N_AUTH_WEBHOOK=https://your-n8n.cloud/webhook/janashakti-authority
VITE_N8N_ESCALATE_WEBHOOK=https://your-n8n.cloud/webhook/escalation
