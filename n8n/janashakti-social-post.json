        240,
        208
      ],
      "webhookId": "ce24d4c0-81ab-4293-88d0-d7ef27a2c22e"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const issueId = $input.item.json.body.issueId;\nconst issueType = $input.item.json.body.issueType;\nconst severity = $input.item.json.body.severity;\nconst location = $input.item.json.body.location;\nconst confirmations = $input.item.json.body.confirmations;\nconst socialConsent = $input.item.json.body.socialConsent;\nconst userXHandle = $input.item.json.body.userXHandle;\n\n// If socialConsent is \"none\", return early with status \"skipped\"\nif (socialConsent === 'none') {\n  return { status: 'skipped', tweetText: '', emailSubject: '', emailBody: '' };\n}\n\n// Build tweet text\nlet tweetText = `🚨 [${severity.toUpperCase()}] ${issueType} reported at ${location}. ${confirmations} citizens confirmed. Track & verify: https://janashakti.web.app/issue/${issueId} #JanaShakti #CivicAlert`;\n\n// Add user handle if socialConsent is \"tag\" and userXHandle exists\nif (socialConsent === 'tag' && userXHandle) {\n  tweetText += ` Reported by @${userXHandle}`;\n}\n\n// Ensure tweet is under 280 characters\nif (tweetText.length > 280) {\n  tweetText = tweetText.substring(0, 277) + '...';\n}\n\n// Build email notification\nconst emailSubject = 'Social Post Triggered';\nconst emailBody = tweetText;\n\nreturn {\n  status: 'ready',\n  tweetText,\n  emailSubject,\n  emailBody,\n  socialConsent\n};"
      },
      "id": "623bce6b-0d3b-4c14-aa5c-caaf1c053e49",
      "name": "Build Tweet & Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        208
      ]
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "and",
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "leftValue": "={{ $json.socialConsent }}",
              "rightValue": "none",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "3a80306b-82a9-4f7f-9eec-d8feb7ad9528",
