{
  "name": "JanaShakti - Social Post",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "janashakti-social",
        "options": {}
      },
      "id": "41c405af-9308-4ee2-8a8f-8fec7cf0e839",
      "name": "Receive Issue Data",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
